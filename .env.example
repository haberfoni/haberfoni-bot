# Veritabanı Bağlantısı
# Docker içinde çalışırken MYSQL_HOST=db (backend network adı)
# Local çalışırken MYSQL_HOST=localhost
DATABASE_URL=mysql://haberfoni_user:your_db_password@db:3306/haberfoni

# Bot, backend'in docker-compose.yml'ındaki MySQL'i kullanır
# Önce haberfoni-backend'i docker-compose up ile başlat!
